<% content_for(:title) { "Issues Being Tracked in Two Rivers, WI" } %>
<% content_for(:description) { "The civic issues in Two Rivers, WI tracked across every city meeting they've appeared at — from first mention through every vote and deferral." } %>

<div class="topics-header">
  <h1 class="page-title">Topics</h1>
  <p class="topics-tagline">What the city is working on</p>
</div>

<div class="topics-content">

<%# === SEARCH === %>
<div class="topics-search-wrap">
  <%= form_with url: topics_path, method: :get, local: true, class: "topics-search-form" do |form| %>
    <div class="topics-search-field">
      <svg class="topics-search-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <circle cx="6.5" cy="6.5" r="5.5"/><line x1="10.5" y1="10.5" x2="15" y2="15"/>
      </svg>
      <%= form.text_field :q,
          value: params[:q],
          placeholder: "Search topics by name or keyword...",
          class: "form-input topics-search-input" %>
    </div>
    <%= form.submit "Search", class: "btn btn--primary" %>
    <% if params[:q].present? %>
      <%= link_to "Clear", topics_path, class: "btn btn--ghost" %>
    <% end %>
  <% end %>
</div>

<% if @search_query %>
  <%# === SEARCH RESULTS === %>
  <section class="topics-section">
    <div class="home-section-header">
      <%= render "shared/atom_marker", size: 20 %>
      <span class="section-label">Results</span>
      <span class="section-line"></span>
    </div>

    <% if @search_results.any? %>
      <div class="topics-list" id="all-topics-cards">
        <% @search_results.each do |topic| %>
          <%= render "topics/topic_card", topic: topic, highlight_signals: {} %>
        <% end %>
      </div>
      <% if @pagy.next %>
        <div class="topics-show-more">
          <%= link_to "Show more results", topics_path(q: params[:q], page: @pagy.next), class: "btn btn--secondary" %>
        </div>
      <% end %>
    <% else %>
      <div class="topics-search-empty">
        <p>No topics found for "<strong><%= params[:q] %></strong>"</p>
        <p class="topics-search-hint">Try a different spelling or a broader keyword.</p>
      </div>
    <% end %>
  </section>

<% elsif @hero_topics.present? || @topics.present? %>

  <%# === WHAT MATTERS NOW === %>
  <% if @hero_topics.present? %>
    <section class="topics-section">
      <div class="home-section-header">
        <%= render "shared/atom_marker", size: 20 %>
        <span class="section-label">What Matters Now</span>
        <span class="section-line"></span>
      </div>

      <div class="topics-hero-grid" id="hero-topics">
        <% @hero_topics.each do |topic| %>
          <%= render "topics/topic_card", topic: topic, highlight_signals: @highlight_signals %>
        <% end %>
      </div>
    </section>
  <% end %>

  <%# === ALL TOPICS === %>
  <% if @topics.present? %>
    <section class="topics-section">
      <div class="home-section-header">
        <%= render "shared/atom_marker", size: 20 %>
        <span class="section-label">All Topics</span>
        <span class="section-line"></span>
        <span id="topics-count" class="topics-count">
          <%= @pagy.to %> of <%= @pagy.count %>
        </span>
      </div>

      <div class="topics-list" id="all-topics-cards" data-section="all-topics">
        <% @topics.each do |topic| %>
          <%= render "topics/topic_card", topic: topic, highlight_signals: {} %>
        <% end %>
      </div>

      <div id="all-topics-page">
        <% if @pagy.next %>
          <div class="topics-show-more">
            <%= link_to topics_path(page: @pagy.next, format: :turbo_stream),
                  class: "btn btn--secondary" do %>
              Show more
            <% end %>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

<% else %>
  <div class="topics-search-empty">
    <p>No active topics right now. Check back after upcoming meetings.</p>
  </div>
<% end %>

</div>
