<% content_for(:title) { "#{@topic.name} - Topics - Two Rivers Matters" } %>

<%# === 1. Topic Header (showpiece, matches home-header treatment) === %>
<div class="topic-header">
  <div class="topic-header-topline">
    <% if @topic.lifecycle_status %>
      <%= topic_lifecycle_badge(@topic.lifecycle_status) %>
    <% end %>
    <% if @briefing %>
      <%= briefing_freshness_badge(@briefing) %>
    <% end %>
  </div>
  <h1 class="topic-header-title"><%= @topic.name %></h1>
  <% if @topic.description.present? %>
    <p class="topic-header-desc"><%= @topic.description %></p>
  <% end %>
</div>

<%# === 2. What to Watch (warm callout) — hidden when no data === %>
<% watch_text = briefing_what_to_watch(@briefing) %>
<% if watch_text.present? %>
  <section class="topic-zone topic-zone--watch">
    <div class="home-section-header">
      <%= render "shared/atom_marker" %>
      <span class="section-label">What to Watch</span>
      <span class="section-line"></span>
    </div>
    <div class="topic-watch-card">
      <p><%= render_inline_markdown(watch_text) %></p>
    </div>
  </section>
<% end %>

<%# === 3. Coming Up (meeting cards or fallback) === %>
<% if @upcoming.any? %>
  <section class="topic-zone topic-zone--upcoming">
    <div class="home-section-header">
      <%= render "shared/atom_marker" %>
      <span class="section-label">Coming Up</span>
      <span class="section-line"></span>
    </div>
    <div class="topic-upcoming-grid">
      <% @upcoming.each do |appearance| %>
        <% is_council = appearance.meeting.body_name.include?("Council") && !appearance.meeting.body_name.include?("Work Session") %>
        <%= link_to meeting_path(appearance.meeting), class: "topic-upcoming-card" do %>
          <div class="date-slab <%= 'council' if is_council %>">
            <span class="date-month"><%= appearance.meeting.starts_at.strftime("%b") %></span>
            <span class="date-day"><%= appearance.meeting.starts_at.strftime("%-d") %></span>
          </div>
          <div class="topic-upcoming-body">
            <div class="topic-upcoming-committee"><%= appearance.meeting.body_name %></div>
            <% if appearance.agenda_item %>
              <div class="topic-upcoming-item"><%= appearance.agenda_item.title %></div>
              <% if public_comment_meeting?(appearance.agenda_item) %>
                <span class="badge badge--info mt-1">Public comment period</span>
              <% end %>
            <% end %>
            <% if appearance.meeting.location.present? %>
              <div class="topic-upcoming-location"><%= appearance.meeting.location %></div>
            <% end %>
          </div>
          <span class="topic-upcoming-arrow">→</span>
        <% end %>
      <% end %>
    </div>
  </section>
<% elsif @typical_committee.present? %>
  <section class="topic-zone topic-zone--upcoming">
    <div class="home-section-header">
      <%= render "shared/atom_marker" %>
      <span class="section-label">Coming Up</span>
      <span class="section-line"></span>
    </div>
    <p class="topic-coming-up-fallback">
      Typically discussed at <strong><%= @typical_committee %></strong>. Check back when the next agenda is published.
    </p>
  </section>
<% end %>

<%# === 4. The Story (editorial showpiece) — hidden when no data === %>
<% story_text = briefing_current_state(@briefing) %>
<% if story_text.present? %>
  <section class="topic-zone topic-zone--story">
    <div class="home-section-header">
      <%= render "shared/atom_marker" %>
      <span class="section-label">The Story</span>
      <span class="section-line"></span>
    </div>
    <article class="topic-story-card">
      <div class="topic-story-accent"></div>
      <div class="topic-story-deco"><%= render "shared/starburst", size: 72, opacity: 0.08 %></div>
      <div class="topic-story-body briefing-editorial-content">
        <%= sanitize(render_briefing_editorial(story_text)) %>
      </div>
      <% concerns = briefing_process_concerns(@briefing) %>
      <% if concerns.any? %>
        <aside class="topic-story-concerns">
          <div class="topic-story-concerns-label">Worth noting</div>
          <ul>
            <% concerns.each do |concern| %>
              <li><%= concern %></li>
            <% end %>
          </ul>
        </aside>
      <% end %>
    </article>
  </section>
<% end %>

<%# === 5. Key Decisions (votes) — hidden when no linked motions === %>
<% if @decisions.any? %>
  <section class="topic-zone topic-zone--decisions">
    <div class="home-section-header">
      <%= render "shared/atom_marker" %>
      <span class="section-label">Key Decisions</span>
      <span class="section-line"></span>
    </div>
    <% @decisions.each do |motion| %>
      <div class="topic-decision-item">
        <div class="topic-decision-header">
          <span class="decision-badge <%= decision_badge_class(motion.outcome) %>">
            <%= motion_outcome_text(motion) %>
          </span>
          <span class="topic-decision-meeting-ref">
            <%= link_to motion.meeting.body_name, meeting_path(motion.meeting) %>,
            <%= motion.meeting.starts_at.strftime("%B %-d, %Y") %>
          </span>
        </div>
        <div class="topic-decision-description"><%= motion.description %></div>
        <% if motion.votes.any? %>
          <div class="votes-label">How they voted</div>
          <div class="votes-grid">
            <% motion.votes.each do |vote| %>
              <div class="vote-card vote-card--<%= vote.value %>">
                <span class="font-bold"><%= vote.member.name %></span>
                <span class="vote-value--<%= vote.value %>"><%= vote.value.titleize %></span>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </section>
<% end %>

<%# === 6. Record (timeline) — always shown === %>
<section class="topic-zone topic-zone--record">
  <div class="home-section-header">
    <%= render "shared/atom_marker" %>
    <span class="section-label">Record</span>
    <span class="section-line"></span>
  </div>
  <% record_entries = briefing_factual_record(@briefing) %>
  <% if record_entries.any? %>
    <div class="topic-timeline">
      <% record_entries.each do |entry| %>
        <% enriched = enrich_record_entry(entry, @record_meetings || {}) %>
        <div class="topic-timeline-entry">
          <div class="topic-timeline-date">
            <%= format_record_date(entry["date"]) %>
          </div>
          <div class="topic-timeline-content">
            <p class="topic-timeline-event"><%= enriched[:event] %></p>
            <% if enriched[:meeting] %>
              <%= link_to enriched[:meeting_name], meeting_path(enriched[:meeting]),
                  class: "topic-timeline-meeting-link" %>
            <% else %>
              <span class="topic-timeline-meeting"><%= enriched[:meeting_name] %></span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="section-empty">No meeting activity recorded for this topic yet.</p>
  <% end %>
</section>

<%# === Footer === %>
<div class="topic-footer">
  <%= link_to "← Back to Topics", topics_path, class: "btn btn--secondary" %>
</div>
