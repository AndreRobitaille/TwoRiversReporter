<% content_for(:title) { "#{@topic.name} - Topics - Two Rivers Matters" } %>

<article class="topic-article">

  <%# === Header === %>
  <header class="topic-article-header">
    <div class="topic-article-topline">
      <% if @topic.lifecycle_status %>
        <%= topic_lifecycle_badge(@topic.lifecycle_status) %>
      <% end %>
      <% if @briefing %>
        <%= briefing_freshness_badge(@briefing) %>
      <% end %>
    </div>
    <h1 class="topic-article-title"><%= @topic.name %></h1>
    <% if @topic.description.present? %>
      <p class="topic-article-dek"><%= @topic.description %></p>
    <% end %>
  </header>

  <%# === What to Watch (pullquote) === %>
  <% watch_text = briefing_what_to_watch(@briefing) %>
  <% if watch_text.present? %>
    <section class="topic-article-section topic-article-section--watch">
      <div class="home-section-header">
        <%= render "shared/atom_marker" %>
        <span class="section-label">What to Watch</span>
        <span class="section-line"></span>
      </div>
      <blockquote class="topic-watch-quote">
        <%= render_inline_markdown(watch_text) %>
      </blockquote>
    </section>
  <% end %>

  <%# === Coming Up === %>
  <% if @upcoming.any? %>
    <section class="topic-article-section topic-article-section--upcoming">
      <div class="home-section-header">
        <%= render "shared/atom_marker" %>
        <span class="section-label">Coming Up</span>
        <span class="section-line"></span>
      </div>
      <ul class="topic-upcoming-list">
        <% @upcoming.each do |appearance| %>
          <% is_council = appearance.meeting.body_name.include?("Council") && !appearance.meeting.body_name.include?("Work Session") %>
          <li class="topic-upcoming-entry">
            <%= link_to meeting_path(appearance.meeting), class: "topic-upcoming-link" do %>
              <time class="topic-upcoming-date <%= 'council' if is_council %>">
                <span class="topic-upcoming-month"><%= appearance.meeting.starts_at.strftime("%b") %></span>
                <span class="topic-upcoming-day"><%= appearance.meeting.starts_at.strftime("%-d") %></span>
              </time>
              <div class="topic-upcoming-detail">
                <div class="topic-upcoming-committee"><%= clean_meeting_display(appearance.meeting.body_name) %></div>
                <% if appearance.agenda_item %>
                  <div class="topic-upcoming-item"><%= appearance.agenda_item.title %></div>
                <% end %>
                <div class="topic-upcoming-meta">
                  <%= appearance.meeting.starts_at.strftime("%-I:%M %p") %>
                  <% if appearance.meeting.location.present? %>
                    · <%= appearance.meeting.location %>
                  <% end %>
                  <% if appearance.agenda_item && public_comment_meeting?(appearance.agenda_item) %>
                    · Public comment
                  <% end %>
                </div>
              </div>
              <span class="topic-upcoming-arrow" aria-hidden="true">→</span>
            <% end %>
          </li>
        <% end %>
      </ul>
    </section>
  <% elsif @typical_committee.present? %>
    <section class="topic-article-section topic-article-section--upcoming">
      <div class="home-section-header">
        <%= render "shared/atom_marker" %>
        <span class="section-label">Coming Up</span>
        <span class="section-line"></span>
      </div>
      <p class="topic-upcoming-fallback">
        Typically discussed at <strong><%= clean_meeting_display(@typical_committee) %></strong>. Check back when the next agenda is published.
      </p>
    </section>
  <% end %>

  <%# === The Story (longform body with drop cap) === %>
  <% story_text = briefing_current_state(@briefing) %>
  <% if story_text.present? %>
    <section class="topic-article-section topic-article-section--story">
      <div class="home-section-header">
        <%= render "shared/atom_marker" %>
        <span class="section-label">The Story</span>
        <span class="section-line"></span>
      </div>
      <div class="topic-story-body">
        <%= sanitize(render_briefing_editorial(story_text)) %>
      </div>
      <% concerns = briefing_process_concerns(@briefing) %>
      <% if concerns.any? %>
        <aside class="topic-aside">
          <span class="topic-aside-label">Worth noting</span>
          <ul>
            <% concerns.each do |concern| %>
              <li><%= concern %></li>
            <% end %>
          </ul>
        </aside>
      <% end %>
    </section>
  <% end %>

  <%# === Key Decisions === %>
  <% if @decisions.any? %>
    <section class="topic-article-section topic-article-section--decisions">
      <div class="home-section-header">
        <%= render "shared/atom_marker" %>
        <span class="section-label">Key Decisions</span>
        <span class="section-line"></span>
      </div>
      <ol class="topic-decisions-list">
        <% @decisions.each do |motion| %>
          <li class="topic-decision">
            <header class="topic-decision-header">
              <span class="decision-badge <%= decision_badge_class(motion.outcome) %>">
                <%= motion_outcome_text(motion) %>
              </span>
              <span class="topic-decision-ref">
                <%= link_to clean_meeting_display(motion.meeting.body_name), meeting_path(motion.meeting) %>
                <span class="topic-decision-sep">·</span>
                <%= motion.meeting.starts_at.strftime("%b %-d, %Y") %>
              </span>
            </header>
            <% if motion.agenda_item&.title.present? %>
              <h3 class="topic-decision-title"><%= motion.agenda_item.title %></h3>
            <% end %>
            <p class="topic-decision-desc"><%= motion.description %></p>
            <% if motion.votes.any? %>
              <div class="votes-grid">
                <% motion.votes.each do |vote| %>
                  <div class="vote-card vote-card--<%= vote.value %>">
                    <span class="font-bold"><%= vote.member.name %></span>
                    <span class="vote-value--<%= vote.value %>"><%= vote.value.titleize %></span>
                  </div>
                <% end %>
              </div>
            <% end %>
          </li>
        <% end %>
      </ol>
    </section>
  <% end %>

  <%# === Record (timeline) === %>
  <section class="topic-article-section topic-article-section--record">
    <div class="home-section-header">
      <%= render "shared/atom_marker" %>
      <span class="section-label">Record</span>
      <span class="section-line"></span>
    </div>
    <% record_entries = briefing_factual_record(@briefing) %>
    <% if record_entries.any? %>
      <ol class="topic-timeline">
        <% record_entries.each do |entry| %>
          <% enriched = enrich_record_entry(entry, @record_meetings || {}) %>
          <li class="topic-timeline-entry">
            <time class="topic-timeline-date"><%= format_record_date(entry["date"]) %></time>
            <div class="topic-timeline-content">
              <p class="topic-timeline-event"><%= enriched[:event] %></p>
              <% if enriched[:meeting] %>
                <%= link_to enriched[:meeting_name], meeting_path(enriched[:meeting]),
                    class: "topic-timeline-meeting-link" %>
              <% else %>
                <span class="topic-timeline-meeting"><%= enriched[:meeting_name] %></span>
              <% end %>
            </div>
          </li>
        <% end %>
      </ol>
    <% else %>
      <p class="section-empty">No meeting activity recorded for this topic yet.</p>
    <% end %>
  </section>

</article>

<div class="topic-article-footer">
  <%= link_to "← All topics", topics_path, class: "btn btn--ghost" %>
</div>
