<%# Locals: topic, highlight_signals (unused, kept for interface compat) %>
<% ref = @meeting_refs&.dig(topic.id) %>
<%= link_to topic_path(topic), class: "topics-card" do %>
  <div class="topics-card-accent"></div>
  <div class="topics-card-body">
    <div class="topics-card-top">
      <h3 class="topics-card-name"><%= topic.name %></h3>
    </div>
    <% if topic.description.present? %>
      <p class="topics-card-desc"><%= truncate(topic.description, length: 100) %></p>
    <% end %>
    <% if topic.topic_briefing&.headline.present? %>
      <p class="topics-card-headline"><%= topic.topic_briefing.headline %></p>
    <% end %>
    <div class="topics-card-footer">
      <% if ref %>
        <span class="topics-card-meta"><%= ref[:date].strftime("%b %-d") %> · <%= ref[:body_name] %></span>
      <% end %>
      <span class="topics-card-cta">Read more &rarr;</span>
    </div>
  </div>
<% end %>
