<%# Locals: topic, highlight_signals (unused, kept for interface compat) %>
<% ref = @meeting_refs&.dig(topic.id) %>
<% generated_image = @topic_generated_images&.[](topic.id) %>
<% has_image = generated_image&.file&.attached? %>
<%= link_to topic_path(topic), class: (has_image ? "topics-card topics-card--with-image" : "topics-card") do %>
  <div class="topics-card-accent"></div>
  <div class="topics-card-body">
    <% if has_image %>
      <div class="topics-card-media">
        <% dimensions = generated_image_dimensions(size: :standard) %>
        <%= image_tag generated_image_variant(generated_image, size: :standard),
          alt: "Illustration for #{topic.name}",
          class: "topics-card-image",
          loading: "lazy",
          decoding: "async",
          width: dimensions[:width],
          height: dimensions[:height] %>
      </div>
    <% end %>
    <div class="topics-card-top">
      <h3 class="topics-card-name"><%= topic.name %></h3>
    </div>
    <% if topic.topic_briefing&.headline.present? %>
      <p class="topics-card-headline"><%= topic.topic_briefing.headline %></p>
    <% end %>
    <div class="topics-card-footer">
      <% if ref %>
        <span class="topics-card-meta"><%= ref[:date].strftime("%b %-d") %> · <%= ref[:body_name] %></span>
      <% end %>
      <span class="topics-card-cta">Read more &rarr;</span>
    </div>
  </div>
<% end %>
