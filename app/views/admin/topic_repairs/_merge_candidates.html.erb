<% if candidates.any? %>
  <div class="space-y-3">
    <% candidates.each do |candidate| %>
      <button
        type="button"
        class="p-3 border rounded bg-white flex items-center justify-between gap-3 w-full text-left"
        data-action="click-><%= select_action %>"
        data-topic-id="<%= candidate.topic_id %>"
        data-topic-name="<%= candidate.name %>"
        data-topic-alias-count="<%= candidate.alias_count %>"
        data-topic-mention-count="<%= candidate.mention_count %>"
        data-topic-summary-count="<%= candidate.summary_count %>"
        data-topic-decision-count="<%= candidate.decision_count %>"
        data-topic-knowledge-link-count="<%= candidate.knowledge_link_count %>"
      >
        <div>
          <div class="font-medium"><%= candidate.name %></div>
          <div class="text-sm text-secondary"><%= candidate.match_reason %></div>
        </div>
      </button>
    <% end %>
  </div>
<% else %>
  <div class="text-sm text-secondary">No merge candidates found.</div>
<% end %>
