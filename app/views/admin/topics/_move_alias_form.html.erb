<details class="topic-alias-repair-move">
  <summary class="topic-alias-repair-move__trigger">
    <span>Move to another topic</span>
    <span class="topic-sidebar-count">+</span>
  </summary>
  <div class="topic-alias-repair-move__body">
    <%= form_with url: move_alias_admin_topic_path(workspace.topic), method: :post, local: true, class: "topic-search-form", data: { controller: "topic-repair-search", topic_repair_search_url_value: merge_candidates_admin_topic_path(workspace.topic, mode: :move_alias), topic_repair_search_action_name_value: "move_alias" } do %>
      <%= hidden_field_tag :alias_id, topic_alias.id %>
      <%= hidden_field_tag :alias_name, topic_alias.name %>
      <%= hidden_field_tag :reason, "move alias under another topic" %>
      <%= hidden_field_tag :q, detail_workspace_context&.dig(:q), data: { topic_repair_search_target: "q" } %>
      <%= hidden_field_tag :source_topic_id, detail_workspace_context&.dig(:source_topic_id), data: { topic_repair_search_target: "sourceTopicId" } %>
      <%= hidden_field_tag :target_topic_id, nil, id: "move_alias_target_topic_id_#{topic_alias.id}", data: { topic_repair_search_target: "targetId" } %>
      <%= hidden_field_tag :target_topic_name, nil, data: { topic_repair_search_target: "targetName" } %>

      <input id="move_alias_search_<%= topic_alias.id %>" type="search" class="form-input w-full" placeholder="Search destination topic" data-topic-repair-search-target="input" data-action="input->topic-repair-search#search">
      <div class="topic-search-form__results" data-topic-repair-search-target="results"></div>
      <div class="topic-search-form__selection" data-topic-repair-search-target="selection">No topic selected yet.</div>

      <div data-topic-repair-search-target="preview">
        <p class="text-sm text-secondary" style="margin: 0;">Select a destination to preview.</p>
      </div>

      <%= submit_tag "Move alias", class: "btn btn--secondary btn--sm", disabled: true, data: { topic_repair_search_target: "submit" } %>
    <% end %>
  </div>
</details>
