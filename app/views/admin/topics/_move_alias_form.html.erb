<details class="w-full mt-2 rounded border border-dashed p-3">
  <summary class="text-sm cursor-pointer font-medium">Move Alias To Another Topic</summary>
  <div class="mt-3 space-y-3">
    <p class="text-xs text-secondary">Search and pick the destination topic, review the impact, then confirm the move.</p>
    <%= form_with url: move_alias_admin_topic_path(workspace.topic), method: :post, local: true, class: "space-y-3", data: { controller: "topic-repair-search", topic_repair_search_url_value: merge_candidates_admin_topic_path(workspace.topic, mode: :move_alias), topic_repair_search_action_name_value: "move_alias" } do %>
      <%= hidden_field_tag :alias_id, topic_alias.id %>
      <%= hidden_field_tag :alias_name, topic_alias.name %>
      <%= hidden_field_tag :reason, "move alias under another topic" %>
      <%= hidden_field_tag :q, detail_workspace_context&.dig(:q), data: { topic_repair_search_target: "q" } %>
      <%= hidden_field_tag :source_topic_id, detail_workspace_context&.dig(:source_topic_id), data: { topic_repair_search_target: "sourceTopicId" } %>
      <%= hidden_field_tag :target_topic_id, nil, id: "move_alias_target_topic_id_#{topic_alias.id}", data: { topic_repair_search_target: "targetId" } %>
      <%= hidden_field_tag :target_topic_name, nil, data: { topic_repair_search_target: "targetName" } %>

        <label class="block text-xs text-secondary" for="move_alias_search_<%= topic_alias.id %>">Target topic search</label>
        <input id="move_alias_search_<%= topic_alias.id %>" type="search" class="form-input w-full" placeholder="Search topics to move into" data-topic-repair-search-target="input" data-action="input->topic-repair-search#search">
        <div class="rounded border p-2 text-sm text-secondary min-h-10 mt-2" data-topic-repair-search-target="results"></div>
        <div class="mt-2 text-sm text-secondary" data-topic-repair-search-target="selection">Choose a topic from search results.</div>

      <div class="rounded bg-base-200 p-3 text-sm" data-topic-repair-search-target="preview">
        <p class="text-secondary">Choose a destination topic to preview the move.</p>
      </div>

      <div class="flex items-center justify-between gap-2">
        <div class="text-xs text-secondary">Confirmation happens when you submit this form.</div>
        <%= submit_tag "Confirm move alias", class: "btn btn--secondary btn--sm", disabled: true, data: { topic_repair_search_target: "submit" } %>
      </div>
    <% end %>
  </div>
</details>
