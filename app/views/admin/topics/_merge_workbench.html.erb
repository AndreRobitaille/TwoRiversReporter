<div class="topic-panel-flow">
  <div class="topic-panel-step">
    <div class="topic-panel-step__number">1</div>
    <div class="topic-panel-step__content">
      <div class="topic-panel-step__label">Search for the duplicate</div>
      <%= form_with url: merge_from_repair_admin_topic_path(workspace.topic), method: :post do |f| %>
        <input id="merge-source-search" type="search" class="form-input w-full" placeholder="Search by name or alias" data-topic-detail-impact-target="search" data-action="input->topic-detail-impact#search" value="<%= params[:q] %>">
        <%= hidden_field_tag :source_topic_id, params[:source_topic_id], data: { topic_detail_impact_target: "source" } %>
        <%= hidden_field_tag :source_topic_name, params[:source_topic_name], data: { topic_detail_impact_target: "sourceName" } %>
        <%= hidden_field_tag :alias_context_q, params[:q], data: { topic_detail_impact_target: "aliasContextQ" } %>
        <%= hidden_field_tag :alias_context_source_topic_id, params[:source_topic_id], data: { topic_detail_impact_target: "aliasContextSource" } %>

        <div class="topic-search-form__results" data-topic-detail-impact-target="results"></div>

        <div class="topic-search-form__selection" data-topic-detail-impact-target="selection">
          <%= if params[:source_topic_name].present?
                "Selected: #{params[:source_topic_name]}"
              elsif params[:source_topic_id].present?
                "Selected topic ID: #{params[:source_topic_id]}"
              else
                "No topic selected yet."
              end %>
        </div>
      </div>
    </div>

    <div class="topic-panel-step">
      <div class="topic-panel-step__number">2</div>
      <div class="topic-panel-step__content">
        <div class="topic-panel-step__label">Review what moves</div>
        <%= render "impact_summary", workspace: preview %>
      </div>
    </div>

    <div class="topic-panel-step">
      <div class="topic-panel-step__number">3</div>
      <div class="topic-panel-step__content">
        <div class="topic-panel-step__label">Confirm merge</div>
        <p class="text-sm text-secondary" style="margin: 0 0 var(--space-2);">The duplicate's aliases, appearances, summaries, and evidence move to <strong><%= workspace.topic.name %></strong>. The duplicate becomes an alias.</p>
        <button type="button" class="btn btn--primary btn--sm" data-action="click->topic-detail-impact#openMergeConfirm">
          Merge into this topic
        </button>
      </div>
    </div>
  <% end %>
</div>
