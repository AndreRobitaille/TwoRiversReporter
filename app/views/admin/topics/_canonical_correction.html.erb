<% if workspace.has_single_alias %>
  <div class="topic-panel-section" style="margin-bottom: var(--space-4);">
    <div class="topic-panel-label">Quick fix — swap with alias</div>
    <p class="text-sm text-secondary" style="margin: 0 0 var(--space-2);">This topic has one alias. Swap which name is canonical without moving any data.</p>
    <%= button_to "Swap names", flip_alias_admin_topic_path(workspace.topic), method: :post, class: "btn btn--secondary btn--sm", params: detail_workspace_context %>
  </div>
<% end %>

<div class="topic-panel-flow">
  <%= form_with url: topic_to_alias_admin_topic_path(workspace.topic), method: :post, local: true, data: { controller: "topic-repair-search", topic_repair_search_url_value: merge_candidates_admin_topic_path(workspace.topic, mode: :topic_to_alias), topic_repair_search_action_name_value: "topic_to_alias" } do %>
    <%= hidden_field_tag :destination_topic_id, nil, data: { topic_repair_search_target: "targetId" } %>
    <%= hidden_field_tag :alias_count, workspace.alias_count %>

    <div class="topic-panel-step">
      <div class="topic-panel-step__number">1</div>
      <div class="topic-panel-step__content">
        <div class="topic-panel-step__label">Find the correct topic</div>
        <input id="canonical_rehome_search_<%= workspace.topic.id %>" type="search" class="form-input w-full" placeholder="Search destination topics" data-topic-repair-search-target="input" data-action="input->topic-repair-search#search">
        <div class="topic-search-form__results" data-topic-repair-search-target="results"></div>
        <div class="topic-search-form__selection" data-topic-repair-search-target="selection">No topic selected yet.</div>
      </div>
    </div>

    <div class="topic-panel-step">
      <div class="topic-panel-step__number">2</div>
      <div class="topic-panel-step__content">
        <div class="topic-panel-step__label">Review transfer</div>
        <div data-topic-repair-search-target="preview">
          <p class="text-sm text-secondary" style="margin: 0;">Select a destination to see what moves.</p>
        </div>
      </div>
    </div>

    <div class="topic-panel-step">
      <div class="topic-panel-step__number">3</div>
      <div class="topic-panel-step__content">
        <div class="topic-panel-step__label">Add reason and confirm</div>
        <p class="text-sm text-secondary" style="margin: 0 0 var(--space-2);"><strong><%= workspace.topic.name %></strong> becomes an alias of the destination. Existing aliases move with it.</p>
        <%= text_area_tag :reason, nil, id: "canonical_rehome_reason_#{workspace.topic.id}", rows: 2, class: "form-input w-full", required: true, placeholder: "Why is this the wrong topic?" %>
        <%= submit_tag "Make this an alias", class: "btn btn--secondary btn--sm", disabled: true, data: { topic_repair_search_target: "submit" } %>
      </div>
    </div>
  <% end %>
</div>
