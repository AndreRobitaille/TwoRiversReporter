<div class="topic-impact-inline" id="impact-summary" data-topic-detail-impact-target="summary">
  <div class="topic-impact-inline__header">Impact preview</div>
  <div class="topic-impact-inline__body">
    <p class="text-sm text-secondary" style="margin: 0 0 var(--space-1);"><%= workspace.consequence %></p>
    <dl>
      <div class="topic-impact-inline__row"><dt>Topics affected</dt><dd><%= workspace.source_topic.present? ? 2 : 1 %></dd></div>
      <div class="topic-impact-inline__row"><dt>Aliases</dt><dd><%= workspace.alias_count %></dd></div>
      <div class="topic-impact-inline__row"><dt>Appearances</dt><dd><%= workspace.appearance_count %></dd></div>
      <div class="topic-impact-inline__row"><dt>Summaries</dt><dd><%= workspace.summary_count %></dd></div>
      <div class="topic-impact-inline__row"><dt>Decisions</dt><dd><%= workspace.decision_count %></dd></div>
    </dl>
  </div>
</div>
