<% content_for(:title) { "#{@workspace.topic.name} - Admin" } %>

<% if flash[:notice] || flash[:alert] %>
  <div class="flash <%= flash[:alert] ? 'flash--danger' : 'flash--success' %> mb-4" data-controller="auto-hide">
    <%= flash[:alert] || flash[:notice] %>
  </div>
<% end %>

<%= render "header_summary", workspace: @workspace %>

<div class="topic-decision-board" data-controller="topic-decision-board topic-detail-impact" data-topic-detail-impact-url-value="<%= impact_preview_admin_topic_path(@workspace.topic) %>">
  <section class="topic-decision-card topic-decision-card--primary" data-topic-decision-board-target="card" data-expanded="true">
    <button type="button" class="topic-decision-card__trigger" data-topic-decision-board-target="trigger" data-action="click->topic-decision-board#toggle" aria-expanded="true">
      <h2 class="topic-decision-card__title">This Topic Is Correct</h2>
      <span class="topic-decision-card__chevron" data-topic-decision-board-target="chevron">Collapse</span>
    </button>
    <div class="topic-decision-card__panel" data-topic-decision-board-target="panel">
      <%= render "merge_workbench", workspace: @workspace, preview: @impact_preview %>
    </div>
  </section>

  <section class="topic-decision-card" data-topic-decision-board-target="card" data-expanded="false">
    <button type="button" class="topic-decision-card__trigger" data-topic-decision-board-target="trigger" data-action="click->topic-decision-board#toggle" aria-expanded="false">
      <h2 class="topic-decision-card__title">This Topic Is Wrong</h2>
      <span class="topic-decision-card__chevron" data-topic-decision-board-target="chevron">Expand</span>
    </button>
    <div class="topic-decision-card__panel" data-topic-decision-board-target="panel" hidden>
      <%= render "canonical_correction", workspace: @workspace, detail_workspace_context: @detail_workspace_context %>
    </div>
  </section>

  <section class="topic-decision-card" data-topic-decision-board-target="card" data-expanded="false">
    <button type="button" class="topic-decision-card__trigger" data-topic-decision-board-target="trigger" data-action="click->topic-decision-board#toggle" aria-expanded="false">
      <h2 class="topic-decision-card__title">Aliases On This Topic</h2>
      <span class="topic-decision-card__chevron" data-topic-decision-board-target="chevron">Expand</span>
    </button>
    <div class="topic-decision-card__panel" data-topic-decision-board-target="panel" hidden>
      <%= render "alias_repair_rail", workspace: @workspace, detail_workspace_context: @detail_workspace_context %>
    </div>
  </section>

  <section class="topic-decision-card topic-decision-card--danger" data-topic-decision-board-target="card" data-expanded="false">
    <button type="button" class="topic-decision-card__trigger" data-topic-decision-board-target="trigger" data-action="click->topic-decision-board#toggle" aria-expanded="false">
      <h2 class="topic-decision-card__title">This Topic Should Not Exist</h2>
      <span class="topic-decision-card__chevron" data-topic-decision-board-target="chevron">Expand</span>
    </button>
    <div class="topic-decision-card__panel" data-topic-decision-board-target="panel" hidden>
      <p class="topic-decision-card__summary">Use this when the record should be blocked or retired instead of repaired.</p>
      <section class="topic-decision-destructive">
        <h3 class="topic-decision-destructive__title">Destructive actions</h3>
        <p class="topic-decision-destructive__lead">Block or retire this topic only when it should no longer be usable. This will add a blocklist entry and keep the topic out of future matching.</p>
        <div class="topic-decision-destructive__preview">
          <div class="topic-decision-destructive__label">Consequence preview</div>
          <p><%= @retire_preview.consequence %></p>
          <p class="topic-decision-destructive__note"><%= @retire_preview.language %></p>
          <dl class="topic-decision-destructive__stats">
            <div class="topic-decision-destructive__stat"><dt>Appearances</dt><dd><%= @retire_preview.appearance_count %></dd></div>
            <div class="topic-decision-destructive__stat"><dt>Agenda items</dt><dd><%= @workspace.topic.agenda_items.count %></dd></div>
            <div class="topic-decision-destructive__stat"><dt>Decisions</dt><dd><%= @retire_preview.decision_count %></dd></div>
            <div class="topic-decision-destructive__stat"><dt>Summaries</dt><dd><%= @retire_preview.summary_count %></dd></div>
          </dl>
        </div>

        <button type="button" class="btn btn--danger" data-action="click->topic-detail-impact#openRetireConfirm" data-modal-id="retire-modal" data-topic-id="<%= @workspace.topic.id %>" data-topic-name="<%= @workspace.topic.name %>">Retire / Block Topic</button>
      </section>
    </div>
  </section>

</div>

<div class="topic-decision-secondary-stack">
  <section class="topic-decision-card topic-decision-card--secondary">
    <%= render "evidence_snapshot", workspace: @workspace %>
  </section>

  <section class="topic-decision-card topic-decision-card--secondary">
    <%= render "history_snapshot", history: @workspace.recent_history %>
  </section>

  <details class="topic-decision-card topic-decision-card--secondary" data-details-collapsible <%= "open" if @topic.errors.any? %>>
      <summary class="topic-decision-details__summary">Edit details</summary>
      <div class="topic-decision-details__body">
        <p class="text-sm text-secondary">Lower-priority metadata editing stays available here, but out of the repair path.</p>

        <%= form_with model: [:admin, @workspace.topic], local: true, class: "topic-decision-details__form" do |f| %>
          <div class="form-group">
            <%= f.label :name, "Canonical name" %>
            <%= f.text_field :name, class: "form-input w-full" %>
          </div>

          <div class="form-group">
            <%= f.label :description, "Description" %>
            <%= f.text_area :description, rows: 4, class: "form-input w-full" %>
          </div>

          <div class="form-group">
            <%= f.label :source_type, "Resident context source" %>
            <%= f.select :source_type,
              options_for_select([
                ["Admin observation", "admin_observation"],
                ["Community observation", "community_observation"],
                ["Social media", "social_media"],
                ["Other", "other"]
              ], @workspace.topic.source_type),
              { include_blank: "Select source" },
              class: "form-input w-full" %>
          </div>

          <div class="form-group">
            <%= f.label :source_notes, "Resident-reported context (no official record)" %>
            <%= f.text_area :source_notes, rows: 4, class: "form-input w-full" %>
          </div>

          <div class="form-group">
            <%= f.label :importance, "Importance (0-10)" %>
            <%= f.number_field :importance, min: 0, max: 10, class: "form-input w-full" %>
          </div>

          <div class="form-group">
            <%= f.label :resident_impact_score, "Resident Impact (1-5)" %>
            <%= f.select :resident_impact_score,
              options_for_select(
                [["--", ""], ["1 - Routine", 1], ["2 - Minor", 2], ["3 - Moderate", 3], ["4 - Significant", 4], ["5 - Major", 5]],
                @workspace.topic.resident_impact_score
              ),
              {},
              class: "form-input w-full" %>
          </div>

          <div class="topic-decision-details__actions">
            <%= f.submit "Save details", class: "btn btn--primary" %>
          </div>
        <% end %>
      </div>
    </details>
</div>

<%= render "repair_confirm_modal", workspace: @workspace %>
