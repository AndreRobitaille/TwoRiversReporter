<% content_for(:title) { "Topic Inbox - Admin" } %>

<div class="page-header">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="page-title">Topic Inbox</h1>
      <p class="page-subtitle">Review AI mistakes, ambiguous cases, and cleanup work.</p>
    </div>
  </div>
</div>

<div class="card">
  <%= form_with url: admin_topics_path, method: :get, local: true, class: "admin-topics-filters" do |f| %>
    <%= f.text_field :q, value: params[:q], placeholder: "Search topics, aliases, description", class: "form-input" %>
    <%= f.select :status,
      options_for_select([["All statuses", ""], ["Proposed", "proposed"], ["Approved", "approved"], ["Blocked", "blocked"]], params[:status]),
      {},
      class: "form-input" %>
    <%= f.select :review_status,
      options_for_select([["All review", ""], ["Needs review", "proposed"], ["Reviewed", "approved"], ["Blocked", "blocked"]], params[:review_status]),
      {},
      class: "form-input" %>
    <%= f.select :lifecycle_status,
      options_for_select([["All lifecycle", ""], ["Active", "active"], ["Dormant", "dormant"], ["Resolved", "resolved"], ["Recurring", "recurring"]], params[:lifecycle_status]),
      {},
      class: "form-input" %>
    <label class="admin-topics-filters__toggle">
      <%= f.check_box :pinned, { checked: params[:pinned] == "true" }, "true", nil %>
      <span>Pinned only</span>
    </label>
    <%= f.submit "Apply", class: "btn btn--primary" %>
    <%= link_to "Reset", admin_topics_path, class: "btn btn--ghost" %>
  <% end %>

  <div class="table-wrapper">
    <table class="admin-topics-table">
      <thead>
        <tr>
          <th><%= link_to "Topic", admin_topics_path(request.query_parameters.merge(sort: "name")), class: "admin-topics-table__sort-link" %></th>
          <th>Status</th>
          <th>Signals</th>
          <th class="text-right"><%= link_to "Mentions", admin_topics_path(request.query_parameters.merge(sort: "mention_count")), class: "admin-topics-table__sort-link" %></th>
          <th><%= link_to "Last Seen", admin_topics_path(request.query_parameters.merge(sort: "last_seen_at")), class: "admin-topics-table__sort-link" %></th>
          <th><%= link_to "Last Activity", admin_topics_path(request.query_parameters.merge(sort: "last_activity_at")), class: "admin-topics-table__sort-link" %></th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @inbox_rows.each do |row| %>
          <%= render "inbox_row", row: row %>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
