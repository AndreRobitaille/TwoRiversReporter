<% if workspace.aliases.any? %>
  <div class="topic-alias-repair-list">
    <% workspace.aliases.each do |topic_alias| %>
      <% remove_preview = Admin::Topics::ImpactPreviewQuery.new(action: :remove_alias, topic: workspace.topic, alias_name: topic_alias.name, alias_count: 1).call %>
      <% promote_preview = Admin::Topics::ImpactPreviewQuery.new(action: :promote_alias, topic: workspace.topic, alias_name: topic_alias.name, alias_count: 1).call %>
      <article class="topic-alias-repair-card">
        <div class="topic-alias-repair-card__header">
          <span class="topic-alias-repair-card__name"><%= topic_alias.name %></span>
          <span class="topic-alias-repair-card__stats">
            <%= remove_preview.appearance_count %> appearances
            &middot;
            <%= remove_preview.summary_count %> summaries
          </span>
        </div>

        <div class="topic-alias-repair-card__actions">
          <div class="topic-alias-repair-action">
            <span class="badge badge--success" style="flex-shrink: 0;">Keep</span>
            <span class="text-sm text-secondary">Leave linked to this topic. No changes.</span>
          </div>

          <div class="topic-alias-repair-action">
            <%= button_to remove_alias_admin_topic_path(workspace.topic), method: :delete, class: "btn btn--secondary btn--sm", form: { data: { turbo_confirm: "Remove #{topic_alias.name}? This alias entry will no longer resolve here." } } do %>
              <%= hidden_field_tag :alias_id, topic_alias.id %>
              <%= hidden_field_tag :reason, "Alias does not belong here" %>
              <%= hidden_field_tag :q, detail_workspace_context&.dig(:q), data: { topic_detail_impact_target: "aliasContextQ" } %>
              <%= hidden_field_tag :source_topic_id, detail_workspace_context&.dig(:source_topic_id), data: { topic_detail_impact_target: "aliasContextSource" } %>
              <%= hidden_field_tag :alias_name, topic_alias.name %>
              Remove
            <% end %>
            <span class="text-sm text-secondary"><%= remove_preview.consequence %></span>
          </div>

          <div class="topic-alias-repair-action">
            <%= button_to promote_alias_admin_topic_path(workspace.topic), method: :post, class: "btn btn--secondary btn--sm", form: { data: { turbo_confirm: "Promote #{topic_alias.name}? Creates a new standalone topic." } } do %>
              <%= hidden_field_tag :alias_id, topic_alias.id %>
              <%= hidden_field_tag :reason, "Alias should be standalone" %>
              <%= hidden_field_tag :q, detail_workspace_context&.dig(:q), data: { topic_detail_impact_target: "aliasContextQ" } %>
              <%= hidden_field_tag :source_topic_id, detail_workspace_context&.dig(:source_topic_id), data: { topic_detail_impact_target: "aliasContextSource" } %>
              Promote
            <% end %>
            <span class="text-sm text-secondary">Becomes its own topic.</span>
          </div>

          <div class="topic-alias-repair-action">
            <%= render "move_alias_form", workspace: workspace, topic_alias: topic_alias, detail_workspace_context: detail_workspace_context %>
          </div>
        </div>
      </article>
    <% end %>
  </div>
<% else %>
  <p class="text-sm text-secondary">No aliases to manage.</p>
<% end %>
