<% content_for(:title) { "#{@meeting.body_name} - #{@meeting.starts_at&.strftime('%B %d, %Y')} - Two Rivers Matters" } %>
<% content_for(:head) do %>
  <meta property="og:title" content="<%= @meeting.body_name %> — <%= @meeting.starts_at&.strftime("%B %-d, %Y") %>">
  <meta property="og:description" content="<%= share_og_description(@summary) %>">
  <meta property="og:url" content="https://<%= MeetingsHelper::PRODUCTION_HOST %>/meetings/<%= @meeting.id %>">
  <meta property="og:type" content="article">
  <meta property="og:site_name" content="Two Rivers Matters">
<% end %>

<article class="meeting-article">

  <%# === Header === %>
  <header class="meeting-article-header">
    <div class="meeting-article-topline">
      <span class="meeting-article-date"><%= @meeting.starts_at&.strftime("%B %-d, %Y") %> · <%= @meeting.starts_at&.strftime("%-l:%M %p") %></span>
    </div>

    <h1 class="meeting-article-title"><%= @meeting.body_name.sub(/ Meeting$/, "") %></h1>

    <div class="meeting-article-docs">
      <% @meeting.meeting_documents
           .select { |d| d.document_type.include?("pdf") && d.source_url.present? }
           .sort_by { |d| d.document_type == "minutes_pdf" ? 0 : d.document_type == "agenda_pdf" ? 1 : 2 }
           .each do |doc| %>
        <%= link_to safe_external_url(doc.source_url), target: "_blank", rel: "noopener", class: "meeting-doc-link" do %>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          <%= doc.document_type.sub("_pdf", "").sub("_html", "").humanize %>
        <% end %>
      <% end %>
      <% transcript = @meeting.meeting_documents.detect { |d| d.document_type == "transcript" && d.source_url.present? } %>
      <% if transcript %>
        <%= link_to safe_external_url(transcript.source_url), target: "_blank", rel: "noopener", class: "meeting-doc-link" do %>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          Watch Recording
        <% end %>
      <% end %>
      <%= link_to safe_external_url(@meeting.detail_page_url), target: "_blank", rel: "noopener", class: "meeting-doc-link meeting-doc-link--muted" do %>
        City Website ↗
      <% end %>
      <span class="meeting-docs-separator"></span>
      <div class="share-wrapper" data-controller="share"
           data-share-text-value="<%= share_text(@meeting, @summary) %>"
           data-share-url-value="https://<%= MeetingsHelper::PRODUCTION_HOST %>/meetings/<%= @meeting.id %>"
           data-action="click@window->share#close keydown.esc@window->share#closeOnEscape">
        <button type="button" class="meeting-doc-link meeting-doc-link--share" data-action="share#toggle" data-share-target="toggleButton">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
          Share
        </button>
        <div class="share-dropdown" data-share-target="dropdown" hidden>
          <button type="button" class="share-dropdown-item" data-action="share#facebook">Share on Facebook</button>
          <button type="button" class="share-dropdown-item" data-action="share#copy" data-share-target="copyButton">Copy summary</button>
        </div>
      </div>
    </div>
  </header>

  <% if @summary&.generation_data&.dig("source_type") == "transcript" %>
    <div class="transcript-banner">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="8" x2="12" y2="12"></line>
        <line x1="12" y1="16" x2="12.01" y2="16"></line>
      </svg>
      This summary is based on the meeting's video recording. It will be updated when official minutes are published.
    </div>
  <% end %>

  <% gd = @summary&.generation_data.presence %>

  <% if gd %>
    <%# === Lede === %>
    <% headline = meeting_headline(gd) %>
    <% if headline.present? %>
      <div class="meeting-article-lede">
        <p><%= headline %></p>
      </div>
    <% else %>
      <p class="section-empty">No summary available for this meeting yet.</p>
    <% end %>

    <%# === Key Decisions === %>
    <% highlights = meeting_highlights(gd) %>
    <% if highlights.any? %>
      <section class="meeting-article-section">
        <div class="home-section-header">
          <%= render "shared/atom_marker" %>
          <span class="section-label">Key Decisions</span>
          <span class="section-line"></span>
        </div>
        <div class="meeting-decisions">
          <% highlights.each do |h| %>
            <div class="meeting-decision">
              <p class="meeting-decision-text"><%= h["text"] %></p>
              <% if h["vote"].present? %>
                <div class="meeting-decision-footer">
                  <span class="decision-badge <%= h["vote"] =~ /^[0-9]+-[0-9]+$/ && h["vote"].split("-").first.to_i > h["vote"].split("-").last.to_i ? 'decision-badge--passed' : 'decision-badge--default' %>">
                    Vote: <%= h["vote"] %>
                  </span>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>

    <%# === Public Input (grouped by topic) === %>
    <% public_inputs = meeting_public_input(gd) %>
    <section class="meeting-article-section">
      <div class="home-section-header">
        <%= render "shared/atom_marker" %>
        <span class="section-label">Public Input<% if public_inputs.any? %> · <%= public_inputs.size %> <%= "speaker".pluralize(public_inputs.size) %><% end %></span>
        <span class="section-line"></span>
      </div>
      <% if public_inputs.any? %>
        <div class="public-input-list">
          <% public_inputs.each do |pi| %>
            <div class="public-input-item">
              <div class="public-input-attribution">
                <% if pi["type"] == "communication" %>
                  <span class="public-input-speaker"><%= pi["speaker"] %></span>
                  <span class="public-input-type">relayed constituent feedback</span>
                <% else %>
                  <span class="public-input-speaker"><%= pi["speaker"] %></span>
                <% end %>
              </div>
              <p class="public-input-summary"><%= pi["summary"]&.gsub(/\s*\[Address redacted\.?\]\s*/i, " ")&.strip %></p>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="section-empty">No public comments or communications recorded for this meeting.</p>
      <% end %>
    </section>

    <%# === Agenda Items === %>
    <% items = meeting_item_details(gd) %>
    <%# Build a lookup of motions by agenda_item_id for vote breakdowns %>
    <% motions_by_item = @meeting.motions.includes(votes: :member).group_by(&:agenda_item_id) %>
    <% if items.any? %>
      <section class="meeting-article-section">
        <div class="home-section-header">
          <%= render "shared/atom_marker" %>
          <span class="section-label">Agenda Items</span>
          <span class="section-line"></span>
        </div>
        <% items.each_with_index do |item, item_idx| %>
          <% matched_agenda_item = @meeting.agenda_items.detect { |ai| ai.title&.downcase&.include?(item["agenda_item_title"]&.downcase&.first(30).to_s) } %>
          <% item_motions = matched_agenda_item ? (motions_by_item[matched_agenda_item.id] || []) : [] %>
          <div class="meeting-item-card" id="agenda-item-<%= item_idx %>">
            <div class="meeting-item-card-header">
              <div class="meeting-item-card-title"><%= item["agenda_item_title"] %></div>
              <% if item["decision"].present? %>
                <span class="decision-badge <%= decision_badge_class(item["decision"]) %>">
                  <%= item["decision"] %><%= " #{item["vote"]}" if item["vote"].present? %>
                </span>
              <% end %>
            </div>

            <% if item["summary"].present? %>
              <div class="meeting-item-card-summary"><%= item["summary"] %></div>
            <% end %>

            <% if item["public_hearing"].present? %>
              <div class="meeting-item-card-hearing">
                Public Input: <%= item["public_hearing"] %>
              </div>
            <% end %>

            <% if item["citations"].present? %>
              <% citations = Array(item["citations"]) %>
              <div class="meeting-item-card-citations">
                <% pdf_doc = @meeting.meeting_documents.detect { |d| d.document_type == "minutes_pdf" && d.source_url.present? } ||
                             @meeting.meeting_documents.detect { |d| d.document_type == "packet_pdf" && d.source_url.present? } %>
                <% if pdf_doc %>
                  <%= link_to safe_external_url(pdf_doc.source_url), target: "_blank", rel: "noopener", class: "meeting-citation-link" do %>
                    📄 See in official document: <%= citations.join(", ") %>
                  <% end %>
                <% else %>
                  Reference: <%= citations.join(", ") %>
                <% end %>
              </div>
            <% end %>

            <%# Roll call votes — expandable %>
            <% if item_motions.any? { |mot| mot.votes.any? } %>
              <% item_motions.select { |mot| mot.votes.any? }.each do |motion| %>
                <details class="meeting-vote-breakdown">
                  <summary class="meeting-vote-toggle">
                    <span>Roll call vote</span>
                    <% yes_count = motion.votes.count { |v| v.value == "yes" } %>
                    <% no_count = motion.votes.count { |v| v.value == "no" } %>
                    <% absent_count = motion.votes.count { |v| v.value == "absent" } %>
                    <span class="meeting-vote-tally">
                      <span class="vote-yes"><%= yes_count %> yes</span>
                      <% if no_count > 0 %><span class="vote-no"><%= no_count %> no</span><% end %>
                      <% if absent_count > 0 %><span class="vote-absent"><%= absent_count %> absent</span><% end %>
                    </span>
                  </summary>
                  <div class="meeting-vote-list">
                    <% motion.votes.sort_by { |v| v.member&.name&.split&.last || "" }.each do |vote| %>
                      <div class="meeting-vote-row">
                        <span class="meeting-vote-member"><%= vote.member&.name || "Unknown" %></span>
                        <span class="meeting-vote-value meeting-vote-value--<%= vote.value %>"><%= vote.value %></span>
                      </div>
                    <% end %>
                  </div>
                </details>
              <% end %>
            <% end %>

            <% if matched_agenda_item&.topics&.approved&.any? %>
              <div class="meeting-item-topics">
                <% matched_agenda_item.topics.approved
                     .sort_by { |t| [-(t.resident_impact_score || 0)] }
                     .each do |topic| %>
                  <%= link_to topic_path(topic), class: "meeting-topic-door" do %>
                    <span class="meeting-topic-door-name"><%= topic.name %></span>
                    <span class="meeting-topic-door-cta">Full history →</span>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </section>
    <% end %>

  <% elsif @summary&.content.present? %>
    <section class="meeting-article-section">
      <div class="home-section-header">
        <%= render "shared/atom_marker" %>
        <span class="section-label"><%= @summary.summary_type == "minutes_recap" ? "Meeting Recap" : "Packet Analysis" %></span>
        <span class="section-line"></span>
      </div>
      <div class="prose meeting-legacy-recap">
        <%= markdown @summary.content %>
      </div>
    </section>

  <% else %>
    <p class="section-empty">No summary available for this meeting yet.</p>
  <% end %>

  <div class="meeting-article-footer">
    <%= link_to meetings_path, class: "back-link" do %>
      ← Back to Meetings
    <% end %>
  </div>

</article>
