<% content_for(:title) { "Meetings - Two Rivers Matters" } %>

<div class="meetings-header">
  <h1 class="page-title">Meetings</h1>
  <p class="meetings-tagline">What happened and what's next</p>
</div>

<div class="meetings-content">

<%# === SEARCH === %>
<div class="meetings-search-wrap">
  <%= form_with url: meetings_path, method: :get, local: true, class: "meetings-search-form" do |form| %>
    <div class="meetings-search-field">
      <svg class="meetings-search-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
        <circle cx="6.5" cy="6.5" r="5.5"/><line x1="10.5" y1="10.5" x2="15" y2="15"/>
      </svg>
      <%= form.text_field :q,
          value: params[:q],
          placeholder: "Search by committee, topic, date, or keyword...",
          class: "form-input meetings-search-input" %>
    </div>
    <%= form.submit "Search", class: "btn btn--primary" %>
    <% if params[:q].present? %>
      <%= link_to "Clear", meetings_path, class: "btn btn--ghost" %>
    <% end %>
  <% end %>
</div>

<% if params[:q].present? %>
  <%# === SEARCH RESULTS === %>
  <section class="meetings-section">
    <div class="home-section-header">
      <%= render "shared/atom_marker", size: 20 %>
      <span class="section-label">Results</span>
      <span class="section-line"></span>
    </div>

    <% if @search_results.any? %>
      <div class="meetings-list">
        <% @search_results.each do |meeting| %>
          <%= render "meetings/meeting_card", meeting: meeting %>
        <% end %>
      </div>
      <% if @pagy.next %>
        <div class="meetings-show-more">
          <%= link_to "Show more results", meetings_path(q: params[:q], page: @pagy.next), class: "btn btn--secondary" %>
        </div>
      <% end %>
    <% else %>
      <div class="meetings-search-empty">
        <p>No meetings found for "<strong><%= params[:q] %></strong>"</p>
        <p class="meetings-search-hint">Try a different spelling, a committee name, or a year like 2025.</p>
      </div>
    <% end %>
  </section>

<% else %>

  <%# === COMING UP === %>
  <section class="meetings-section">
    <div class="home-section-header">
      <%= render "shared/atom_marker", size: 20 %>
      <span class="section-label">Coming Up</span>
      <span class="section-line"></span>
    </div>

    <% if @upcoming_enriched.any? %>
      <div class="meetings-list">
        <% @upcoming_enriched.each do |meeting| %>
          <%= render "meetings/meeting_card", meeting: meeting %>
        <% end %>
      </div>
    <% end %>

    <% if @upcoming_thin.any? %>
      <details class="meetings-more" <%= 'open' if @upcoming_enriched.empty? %>>
        <summary class="meetings-more-toggle">
          <span class="meetings-more-count"><%= @upcoming_thin.size %></span>
          other <%= "meeting".pluralize(@upcoming_thin.size) %> scheduled
          <span class="meetings-more-hint">— agendas not yet posted</span>
        </summary>
        <div class="meetings-more-list">
          <% @upcoming_thin.each do |meeting| %>
            <%= link_to meeting_path(meeting), class: "meetings-compact-row" do %>
              <span class="meetings-compact-date"><%= meeting.starts_at.strftime("%b %-d") %></span>
              <span class="meetings-compact-name"><%= meeting.body_name.sub(/ Meeting$/, "") %></span>
              <span class="meetings-compact-time"><%= meeting.starts_at.strftime("%-l:%M %p") %></span>
            <% end %>
          <% end %>
        </div>
      </details>
    <% elsif @upcoming_enriched.empty? %>
      <p class="meetings-empty-note">No upcoming meetings scheduled</p>
    <% end %>
  </section>

  <%# === WHAT HAPPENED === %>
  <section class="meetings-section">
    <div class="home-section-header">
      <%= render "shared/atom_marker", size: 20 %>
      <span class="section-label">What Happened</span>
      <span class="section-line"></span>
    </div>

    <% if @recent_enriched.any? %>
      <div class="meetings-list">
        <% @recent_enriched.each do |meeting| %>
          <%= render "meetings/meeting_card", meeting: meeting %>
        <% end %>
      </div>
    <% end %>

    <% if @recent_thin.any? %>
      <details class="meetings-more">
        <summary class="meetings-more-toggle">
          <span class="meetings-more-count"><%= @recent_thin.size %></span>
          other recent <%= "meeting".pluralize(@recent_thin.size) %>
          <span class="meetings-more-hint">— no summaries yet</span>
        </summary>
        <div class="meetings-more-list">
          <% @recent_thin.each do |meeting| %>
            <%= link_to meeting_path(meeting), class: "meetings-compact-row" do %>
              <span class="meetings-compact-date"><%= meeting.starts_at.strftime("%b %-d") %></span>
              <span class="meetings-compact-name"><%= meeting.body_name.sub(/ Meeting$/, "") %></span>
            <% end %>
          <% end %>
        </div>
      </details>
    <% elsif @recent_enriched.empty? %>
      <p class="meetings-empty-note">No recent meetings with summaries yet</p>
    <% end %>
  </section>

<% end %>

</div>
