<% content_for(:title) { "Committees - Two Rivers Matters" } %>

<div class="committees-header">
  <h1 class="page-title">Committees</h1>
  <p class="committees-tagline">Who has power and how it flows</p>
</div>

<%# === Diagram === %>
<div class="committees-diagram-wrap" id="committees-diagram">
  <p class="committees-diagram-caption">How committees connect — click to expand</p>
  <div class="committees-diagram-content" onclick="document.getElementById('committees-diagram').classList.toggle('is-expanded')">
    <%= image_tag "committee-connections.png",
        alt: "Diagram showing how Two Rivers committees relate to each other",
        class: "committees-diagram" %>
  </div>
</div>

<%# === City Council — Hero Zone === %>
<% if @council %>
  <a href="<%= committee_path(@council.slug) %>" class="committees-council-hero">
    <span class="badge badge--primary">Elected by voters</span>
    <span class="committees-council-name">City Council</span>
    <span class="committees-council-desc"><%= CommitteesController::CARD_DESCRIPTIONS["City Council"] %></span>
    <span class="committees-card-cta">View members & activity &rarr;</span>
  </a>
<% end %>

<%# === Governance Sections === %>
<% CommitteesController::GOVERNANCE_SECTIONS.each do |section| %>
  <% committees = @governance_groups[section[:key]] %>
  <% next if committees.blank? %>

  <section class="committees-section">
    <div class="home-section-header">
      <%= render "shared/atom_marker" %>
      <span class="section-label"><%= section[:label] %></span>
      <span class="section-line"></span>
    </div>
    <p class="committees-section-desc"><%= section[:description] %></p>

    <div class="committees-grid">
      <% committees.each do |committee| %>
        <%= link_to committee_path(committee.slug), class: "committees-card" do %>
          <span class="committees-card-name"><%= committee.name %></span>
          <% desc = CommitteesController::CARD_DESCRIPTIONS[committee.name] %>
          <% if desc.present? %>
            <span class="committees-card-desc"><%= desc %></span>
          <% end %>
          <span class="committees-card-cta">View details &rarr;</span>
        <% end %>
      <% end %>
    </div>
  </section>
<% end %>
