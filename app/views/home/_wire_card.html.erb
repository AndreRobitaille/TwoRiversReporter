<%# Mid-tier wire card. Locals: topic, headline, meeting_ref %>
<% generated_image = @topic_generated_images&.[](topic.id) %>
<% has_image = generated_image&.file&.attached? %>
<%= link_to topic_path(topic), class: (has_image ? "wire-card wire-card--with-image" : "wire-card") do %>
  <% if has_image %>
    <div class="wire-media">
      <%= image_tag generated_image.file, alt: "Illustration for #{topic.name}", class: "wire-image", loading: "lazy", decoding: "async" %>
    </div>
  <% end %>
  <div class="wire-body">
    <div class="wire-topic"><%= topic.name %></div>
    <% if headline.present? %>
      <p class="wire-headline"><%= truncate(headline, length: 120) %></p>
    <% end %>
    <div class="wire-footer">
      <% if meeting_ref %>
        <span class="wire-meta"><%= meeting_ref[:date]&.strftime("%b %-d") %> · <%= meeting_ref[:body_name]&.sub(/ Meeting$/, "") %></span>
      <% else %>
        <span class="wire-meta"></span>
      <% end %>
      <span class="wire-read">Full story →</span>
    </div>
  </div>
<% end %>
