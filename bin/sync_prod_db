#!/usr/bin/env bash
#
# bin/sync_prod_db — Sync production Postgres to local development.
#
# Streams a pg_dump from the production Postgres container via SSH, drops and
# recreates the local development database, restores the dump, and scrubs
# admin auth so a leaked/shared dev DB can't be used to log in.
#
# Usage:
#   bin/sync_prod_db           # interactive, prompts before dropping local DB
#   bin/sync_prod_db --force   # skip the confirmation prompt
#   bin/sync_prod_db --help
#
# What it does NOT do:
#   - Does not touch the production DB (read-only via pg_dump).
#   - Does not sync ActiveStorage blob files under /rails/storage. Document
#     PDFs/images will have broken references locally. If you need them, rsync
#     the volume separately.
#   - Does not touch the Solid Queue / Cache / Cable databases. The primary
#     DB's solid_queue_* tables are kept for schema but their data is dropped.
#
# Prerequisites:
#   - SSH access to the VPS with the Kamal deploy key.
#   - Local PostgreSQL running and accessible as the current user.
#   - No active connections to two_rivers_reporter_development (stop bin/dev
#     and close rails consoles first).

set -euo pipefail

# --- Config ---------------------------------------------------------------

VPS_HOST="178.156.250.235"
VPS_USER="root"
SSH_KEY="${HOME}/.ssh/andreg7-id_ed25519"
DB_CONTAINER="two_rivers_reporter-db"
PROD_DB_NAME="two_rivers_reporter_production"
PROD_DB_USER="two_rivers_reporter"
LOCAL_DB_NAME="two_rivers_reporter_development"

DUMP_DIR="${TMPDIR:-/tmp}"
DUMP_FILE="${DUMP_DIR}/tworivers_prod_$(date +%Y-%m-%d_%H%M%S).sql"

FORCE=0
for arg in "$@"; do
  case "$arg" in
    --force|-f) FORCE=1 ;;
    --help|-h)
      sed -n '2,30p' "$0" | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    *)
      echo "Unknown argument: $arg" >&2
      echo "Run 'bin/sync_prod_db --help' for usage." >&2
      exit 1
      ;;
  esac
done

# --- Helpers --------------------------------------------------------------

info()  { printf '\033[1;34m==>\033[0m %s\n' "$*"; }
warn()  { printf '\033[1;33m==>\033[0m %s\n' "$*" >&2; }
error() { printf '\033[1;31m==>\033[0m %s\n' "$*" >&2; }

cleanup() {
  if [[ -f "$DUMP_FILE" ]]; then
    rm -f "$DUMP_FILE"
  fi
}
trap cleanup EXIT

# --- Preflight ------------------------------------------------------------

info "Preflight checks"

if [[ ! -f "$SSH_KEY" ]]; then
  error "SSH key not found at $SSH_KEY"
  exit 1
fi

if ! command -v psql >/dev/null || ! command -v pg_dump >/dev/null; then
  error "psql/pg_dump not installed locally"
  exit 1
fi

if [[ ! -x bin/rails ]]; then
  error "bin/rails not found — run this from the project root"
  exit 1
fi

# Warn (don't block) if dev server or console appears to be running.
if pgrep -f 'rails server|rails console|bin/dev|puma' >/dev/null 2>&1; then
  warn "A Rails process appears to be running. dropdb may fail if it holds a connection."
fi

# --- Confirm --------------------------------------------------------------

if [[ "$FORCE" != "1" ]]; then
  echo
  warn "This will DROP the local database '$LOCAL_DB_NAME' and replace it with production data."
  read -r -p "Proceed? [y/N] " reply
  case "$reply" in
    y|Y|yes|YES) ;;
    *) echo "Aborted."; exit 0 ;;
  esac
fi

# --- Dump prod ------------------------------------------------------------

info "Dumping $PROD_DB_NAME from $VPS_HOST"

# Dump flags:
#   --no-owner / --no-privileges  — prod role 'two_rivers_reporter' doesn't exist locally
#   --exclude-table-data=...      — keep schema but drop data for ephemeral/sensitive tables
#
# We then strip pgvector lines via grep: local Postgres 18 doesn't have the
# extension available, and prod's knowledge_chunks.embedding is still a json
# column (the migration deferred pgvector), so there's no data loss.
ssh -i "$SSH_KEY" -o ConnectTimeout=15 "${VPS_USER}@${VPS_HOST}" \
  "docker exec $DB_CONTAINER pg_dump \
    -U $PROD_DB_USER \
    -d $PROD_DB_NAME \
    --no-owner \
    --no-privileges \
    '--exclude-table-data=solid_queue_*' \
    --exclude-table-data=sessions" \
  | grep -v -E '(CREATE|COMMENT ON) EXTENSION.*vector' \
  > "$DUMP_FILE"

if [[ ! -s "$DUMP_FILE" ]]; then
  error "Dump file is empty — something went wrong"
  exit 1
fi

dump_size=$(du -h "$DUMP_FILE" | awk '{print $1}')
info "Dump written to $DUMP_FILE ($dump_size)"

# --- Drop + recreate local DB --------------------------------------------

info "Dropping and recreating $LOCAL_DB_NAME"
dropdb --if-exists "$LOCAL_DB_NAME"
createdb "$LOCAL_DB_NAME"

# --- Restore --------------------------------------------------------------

info "Restoring into $LOCAL_DB_NAME"
psql -d "$LOCAL_DB_NAME" -v ON_ERROR_STOP=1 -q -f "$DUMP_FILE" >/dev/null

# --- Scrub auth -----------------------------------------------------------

info "Scrubbing admin auth (password → 'password', TOTP cleared)"
# update_all bypasses callbacks, validations, and dirty tracking — which matters
# because `encrypts :totp_secret` can trip AR encryption when reading old values
# via the normal update! path.
bin/rails runner -e development '
  digest = BCrypt::Password.create("password")
  count = User.update_all(
    password_digest: digest,
    totp_secret: nil,
    totp_enabled: false,
    recovery_codes_digest: []
  )
  puts "  scrubbed #{count} user(s)"
'

# --- Verify ---------------------------------------------------------------

info "Verifying restore"
psql -d "$LOCAL_DB_NAME" -q <<'SQL'
\pset border 0
SELECT 'meetings'      AS table, COUNT(*) FROM meetings
UNION ALL SELECT 'topics',         COUNT(*) FROM topics
UNION ALL SELECT 'topic_briefings', COUNT(*) FROM topic_briefings
UNION ALL SELECT 'users',           COUNT(*) FROM users
UNION ALL SELECT 'committees',      COUNT(*) FROM committees;
SQL

echo
info "Done."
echo "  Local DB:  $LOCAL_DB_NAME"
echo "  Admin login: email from production, password = 'password'"
echo "  To see admin emails: bin/rails runner 'puts User.pluck(:email_address)'"
